*.hive
SAM
SYSTEM
SECURITY
NTDS.dit
*.potfile
*.pot

# Wordlists (too large for git; download separately)
wordlists/rockyou.txt
wordlists/*.txt
!wordlists/example_wordlist.txt

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.bak
/tmp/
